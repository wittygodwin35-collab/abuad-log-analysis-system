# Supabase runtime URL: prefer the pooler endpoint for Prisma app traffic.
# If you only have the direct host, you can temporarily reuse the DIRECT_URL value here.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# Supabase direct URL: use the direct database host for db push and migrations.
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<publishable-key>"
ML_SERVICE_URL="http://127.0.0.1:8001"
NORMAL_LOG_DIR="mini-services/ml-analyzer/data/normal"
EVALUATION_DATASET_DIR=""
LOG_COLLECTOR_PATHS="/var/log/auth.log,/var/log/syslog,/var/log/nginx/access.log,/var/log/nginx/error.log,/var/log/apache2/access.log,/var/log/apache2/error.log"
COLLECTOR_INTERVAL_SECONDS="300"
ML_SERVICE_PORT="8001"
PRISMA_LOG_QUERIES="false"
